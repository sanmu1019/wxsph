# Server
WXSPH_HOST=0.0.0.0
WXSPH_PORT=8787
WXSPH_TIMEOUT=18
WXSPH_DEBUG=false

# Required. Keep this private and never commit a real cookie.
WXSPH_COOKIE=replace_with_yuanbao_cookie

# Optional. Multiple cookies can be separated with ||
# WXSPH_COOKIES=cookie_a||cookie_b

# Optional. Comma or whitespace separated keys. If set, callers must pass one.
WXSPH_API_KEYS=change_me_to_a_long_random_key

# Optional protection.
WXSPH_RATE_LIMIT_PER_MIN=30
WXSPH_CACHE_TTL=600
WXSPH_CACHE_FILE=wxsph_cache.json
# Set true only when the app sits behind a trusted reverse proxy.
WXSPH_TRUST_PROXY=false
